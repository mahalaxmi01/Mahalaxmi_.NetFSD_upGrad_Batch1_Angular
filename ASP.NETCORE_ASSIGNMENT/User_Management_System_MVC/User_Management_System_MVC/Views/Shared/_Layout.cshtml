<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - User Management</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="User" asp-action="Login">User Management</a>

            <div class="ms-auto">
                <a class="btn btn-outline-light me-2" asp-controller="User" asp-action="Register">Register</a>
                <a class="btn btn-outline-light me-2" asp-controller="User" asp-action="Login">Login</a>
                <a class="btn btn-outline-light me-2" asp-controller="User" asp-action="Profile">Profile</a>
                <a class="btn btn-danger" asp-controller="User" asp-action="Logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>